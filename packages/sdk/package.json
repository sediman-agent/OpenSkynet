{
  "name": "@sediman/sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "Sediman SDK — client, server, and module implementations",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./transport": {
      "import": "./dist/transport.js",
      "types": "./dist/transport.d.ts"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "typescript": "^5.7.0"
  }
}
